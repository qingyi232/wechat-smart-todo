.login-page {
  min-height: 100vh;
  position: relative;
  padding: 0;
}

.bg-pattern {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 700rpx;
  z-index: 0;
}

.bg-mask {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 700rpx;
  background: linear-gradient(180deg,
    rgba(46, 170, 138, 0.75) 0%,
    rgba(46, 170, 138, 0.95) 60%,
    var(--bg-page) 100%);
  z-index: 1;
}

.logo-area {
  position: relative;
  z-index: 2;
  padding-top: 180rpx;
  text-align: center;
  color: #fff;
}

.logo-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.12);
}

.logo-emoji {
  font-size: 80rpx;
  color: #fff;
  font-weight: 300;
}

.logo-title {
  font-size: 56rpx;
  font-weight: 800;
  margin-top: 32rpx;
  letter-spacing: 4rpx;
}

.logo-subtitle {
  font-size: 26rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

.form-card {
  position: relative;
  z-index: 2;
  margin: 60rpx 48rpx 0;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.1);
}

.form-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.form-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.input-group {
  margin-top: 36rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  background: var(--bg-input);
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.avatar-picker {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 4rpx solid #e0e0e0;
}

.avatar-tip {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx;
  background: var(--bg-input, #f5f5f5);
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-top: 24rpx;
  text-align: center;
}

.btn-login {
  margin-top: 40rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2EAA8A, #3FBF9D);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 100rpx;
  line-height: 96rpx;
  box-shadow: 0 12rpx 24rpx rgba(46, 170, 138, 0.3);
}

.btn-login[disabled] {
  opacity: 0.6;
}

.quick-login {
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--border);
}

.quick-title {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 20rpx;
}

.btn-quick {
  width: 100%;
  height: 80rpx;
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: 26rpx;
  border-radius: 100rpx;
  line-height: 80rpx;
  border: 1rpx solid var(--border);
}

.login-tips {
  margin-top: 28rpx;
  font-size: 22rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
}

.footer {
  text-align: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
  color: var(--text-hint);
  font-size: 22rpx;
}
