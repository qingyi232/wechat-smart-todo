<view class="page">
  <!-- 顶部标题区 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="page-title">数据统计</view>
      <view class="page-desc">让每一份努力都看得见</view>
    </view>
  </view>

  <!-- 核心指标 -->
  <view class="metric-grid">
    <view class="metric-card completion">
      <view class="metric-icon">🎯</view>
      <view class="metric-value">{{data.completionRate || 0}}%</view>
      <view class="metric-label">完成率</view>
      <view class="progress-bar"><view class="progress-fill" style="width:{{data.completionRate || 0}}%;background:#2EAA8A"></view></view>
    </view>
    <view class="metric-card streak">
      <view class="metric-icon">🔥</view>
      <view class="metric-value">{{data.streakDays || 0}}<text class="metric-unit">天</text></view>
      <view class="metric-label">连续打卡</view>
    </view>
  </view>

  <view class="metric-grid">
    <view class="metric-card small">
      <view class="metric-value-sm">{{data.base.total || 0}}</view>
      <view class="metric-label-sm">累计待办</view>
    </view>
    <view class="metric-card small">
      <view class="metric-value-sm" style="color:#5B8DEF">{{data.base.completed || 0}}</view>
      <view class="metric-label-sm">已完成</view>
    </view>
    <view class="metric-card small">
      <view class="metric-value-sm" style="color:#F59E5B">{{data.base.active || 0}}</view>
      <view class="metric-label-sm">进行中</view>
    </view>
    <view class="metric-card small">
      <view class="metric-value-sm" style="color:#EF5A6F">{{data.base.overdue || 0}}</view>
      <view class="metric-label-sm">已逾期</view>
    </view>
  </view>

  <!-- 近7天完成趋势 -->
  <view class="chart-card">
    <view class="chart-title">近7天完成趋势</view>
    <view class="bar-chart">
      <view class="bar-group" wx:for="{{data.weekTrend}}" wx:key="date">
        <view class="bar-bg">
          <view class="bar-created" style="height:{{item.createdPct}}%"></view>
          <view class="bar-completed" style="height:{{item.completedPct}}%"></view>
        </view>
        <view class="bar-count">{{item.completed}}</view>
        <view class="bar-label">{{item.date}}</view>
      </view>
    </view>
    <view class="chart-legend">
      <view class="legend-item"><view class="legend-dot" style="background:#2EAA8A"></view>完成</view>
      <view class="legend-item"><view class="legend-dot" style="background:#E8F5EF"></view>新增</view>
    </view>
  </view>

  <!-- 分类占比 -->
  <view class="chart-card">
    <view class="chart-title">分类分布</view>
    <view class="category-list">
      <view class="category-row" wx:for="{{data.byCategory}}" wx:key="name">
        <view class="category-head">
          <view class="category-name">
            <view class="cat-dot" style="background:{{item.color}}"></view>
            {{item.name}}
          </view>
          <view class="category-count">{{item.count}}</view>
        </view>
        <view class="category-bar-bg">
          <view class="category-bar-fill" style="width:{{item.pct}}%;background:{{item.color}}"></view>
        </view>
      </view>
      <view class="empty-cat" wx:if="{{data.byCategory.length === 0}}">暂无分类数据</view>
    </view>
  </view>

  <!-- 优先级分布 -->
  <view class="chart-card">
    <view class="chart-title">未完成 - 按优先级</view>
    <view class="priority-list">
      <view class="priority-bar-row" wx:for="{{data.byPriority}}" wx:key="priority">
        <view class="pr-label" style="background:{{priorityColors[item.priority]}}20;color:{{priorityColors[item.priority]}}">
          {{priorityLabels[item.priority]}}
        </view>
        <view class="pr-bar-bg">
          <view class="pr-bar-fill" style="width:{{item.pct}}%;background:{{priorityColors[item.priority]}}"></view>
        </view>
        <view class="pr-count">{{item.count}}</view>
      </view>
      <view class="empty-cat" wx:if="{{data.byPriority.length === 0}}">暂无待办</view>
    </view>
  </view>

  <!-- 本月完成 -->
  <view class="chart-card month-card">
    <view style="display:flex;align-items:center;gap:20rpx">
      <view class="month-icon">📅</view>
      <view>
        <view class="month-title">本月已完成</view>
        <view class="month-value">{{data.monthCompleted || 0}} <text style="font-size:28rpx;font-weight:400;color:var(--text-secondary)">件</text></view>
      </view>
    </view>
    <view class="month-motto">{{motto}}</view>
  </view>

</view>
