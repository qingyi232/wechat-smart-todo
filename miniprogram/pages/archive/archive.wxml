<view class="page">
  <view class="stat-banner">
    <view>
      <view class="banner-label">已完成</view>
      <view class="banner-value">{{todos.length}} <text class="unit">件</text></view>
    </view>
    <image class="banner-icon" src="https://api.iconify.design/carbon:task-complete.svg?color=%232EAA8A" mode="aspectFit" />
  </view>

  <view class="todo-list" wx:if="{{todos.length > 0}}">
    <view class="todo-item" wx:for="{{todos}}" wx:key="id">
      <view class="check-done" style="background:{{item.category_color}}">✓</view>
      <view class="todo-body">
        <view class="todo-title">{{item.title}}</view>
        <view class="todo-meta">
          <view class="category-tag" style="background:{{item.category_color}}20;color:{{item.category_color}}">
            {{item.category_name || '未分类'}}
          </view>
          <text class="completed-at">完成于 {{item.completed_text}}</text>
        </view>
      </view>
      <view class="todo-actions">
        <view class="action-btn restore" bindtap="onRestore" data-id="{{item.id}}">恢复</view>
        <view class="action-btn delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <image src="https://api.iconify.design/carbon:task-complete.svg?color=%232EAA8A" mode="aspectFit" style="width:160rpx;height:160rpx;opacity:0.3" />
    <view style="margin-top:20rpx">暂无已完成的待办</view>
    <view class="hint">完成待办后会自动归档到此处</view>
  </view>
</view>
