.page {
  padding-bottom: 160rpx;
  min-height: 100vh;
}

.hero {
  position: relative;
  padding: 120rpx 40rpx 100rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #2EAA8A 0%, #3FBF9D 60%, #F59E5B 160%);
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
  color: #fff;
}

.greet-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.greet {
  font-size: 28rpx;
  opacity: 0.95;
}

.user-name {
  font-size: 48rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.hero-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.4);
  background: #fff;
}

.quote {
  margin-top: 24rpx;
  font-size: 26rpx;
  opacity: 0.95;
  line-height: 1.6;
  font-style: italic;
}

.overview {
  display: flex;
  gap: 20rpx;
  margin: -60rpx 32rpx 0;
  position: relative;
  z-index: 2;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(27, 42, 53, 0.08);
}

.stat-value {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  margin-top: 8rpx;
  color: var(--text-secondary);
}

.stat-card.primary .stat-value { color: #2EAA8A; }
.stat-card.accent  .stat-value { color: #F59E5B; }
.stat-card.warning .stat-value { color: #EF5A6F; }
.stat-card.success .stat-value { color: #5B8DEF; }

.search-bar {
  margin: 32rpx;
  padding: 0 24rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(27,42,53,0.04);
}

.search-icon { width: 32rpx; height: 32rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.clear-btn {
  width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center;
  color: var(--text-hint); font-size: 24rpx;
}

.filter-bar {
  white-space: nowrap;
  padding: 0 32rpx 12rpx;
}

.filter-chip {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 14rpx;
  background: #fff;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
  transition: all 0.15s;
}

.filter-chip.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  box-shadow: 0 4rpx 12rpx rgba(46,170,138,0.25);
}

.filter-chip.category-chip {
  display: inline-flex;
  align-items: center;
}

.cat-dot {
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.todo-list {
  padding: 0 32rpx;
}

.todo-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(27,42,53,0.04);
  transition: all 0.2s;
}

.todo-item:active {
  transform: scale(0.98);
}

.todo-check {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--primary);
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-mark {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.todo-item.done .todo-title {
  text-decoration: line-through;
  color: var(--text-hint);
}

.todo-item.overdue {
  border-left: 6rpx solid var(--danger);
}

.todo-body { flex: 1; min-width: 0; }

.todo-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.todo-meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.category-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.priority-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.priority-dot[data-priority="1"] { background: #9CA3AF; }
.priority-dot[data-priority="2"] { background: #5B8DEF; }
.priority-dot[data-priority="3"] { background: #F59E5B; }
.priority-dot[data-priority="4"] { background: #EF5A6F; }

.priority-label {
  font-size: 22rpx;
}

.due-date {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.overdue .due-date { color: var(--danger); font-weight: 600; }

.repeat-icon {
  opacity: 0.7;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
  color: var(--text-hint);
}

.empty-state .hint {
  font-size: 24rpx;
  margin-top: 12rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #2EAA8A, #3FBF9D);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(46, 170, 138, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
}
