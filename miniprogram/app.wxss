/* 全局样式 - 清新薄荷绿 + 暖橙 + 米白 */
page {
  --primary: #2EAA8A;
  --primary-dark: #248D72;
  --primary-light: #E8F5EF;
  --primary-very-light: #F0FAF5;
  --accent: #F59E5B;
  --accent-light: #FFF4E8;
  --danger: #EF5A6F;
  --danger-light: #FEE7EB;
  --warning: #F0B84F;
  --info: #5B8DEF;
  --text-primary: #1B2A35;
  --text-secondary: #5C6B76;
  --text-hint: #9CA3AF;
  --bg-page: #FAFAF7;
  --bg-card: #FFFFFF;
  --bg-input: #F5F6F4;
  --border: #EAECE9;
  --shadow-sm: 0 2rpx 8rpx rgba(27, 42, 53, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(27, 42, 53, 0.08);
  --shadow-lg: 0 16rpx 40rpx rgba(46, 170, 138, 0.12);

  background: var(--bg-page);
  color: var(--text-primary);
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2EAA8A 0%, #3FBF9D 100%);
  color: #fff;
  border-radius: 100rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(46, 170, 138, 0.25);
  transition: all 0.2s;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(46, 170, 138, 0.2);
}

.btn-ghost {
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 100rpx;
  padding: 20rpx 32rpx;
  font-weight: 600;
  text-align: center;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-primary { color: var(--primary); }
.text-accent { color: var(--accent); }
.text-danger { color: var(--danger); }
.text-hint { color: var(--text-hint); }
.text-secondary { color: var(--text-secondary); }

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin: 8rpx 0 24rpx;
  letter-spacing: 0.5rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-hint);
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-state .hint {
  font-size: 26rpx;
  margin-top: 12rpx;
}

.divider {
  height: 2rpx;
  background: var(--border);
  margin: 24rpx 0;
}

.avatar {
  border-radius: 50%;
  background: var(--primary-light);
}

.loading-wrap {
  padding: 80rpx 0;
  text-align: center;
  color: var(--text-hint);
}
