.page {
  padding: 32rpx;
  min-height: 100vh;
}

.header-tip {
  padding: 16rpx 24rpx;
  background: var(--primary-very-light);
  border-radius: 12rpx;
  color: var(--primary);
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.cat-list { display: flex; flex-direction: column; gap: 16rpx; }

.cat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-sm);
}

.cat-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cat-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
}

.cat-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.cat-count { font-size: 22rpx; color: var(--text-hint); margin-top: 4rpx; }

.cat-actions {
  display: flex;
  gap: 12rpx;
}

.act-btn {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 24rpx;
}

.act-btn.del {
  background: var(--danger-light);
  color: var(--danger);
}

.add-btn {
  margin-top: 40rpx;
  padding: 28rpx;
  border: 2rpx dashed var(--primary);
  border-radius: 20rpx;
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--primary-very-light);
}

.add-icon { font-size: 38rpx; }

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  width: 620rpx;
  padding: 48rpx 40rpx 32rpx;
}

.modal-title { font-size: 36rpx; font-weight: 700; text-align: center; margin-bottom: 32rpx; }

.modal-field { margin-bottom: 24rpx; }
.modal-label { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.modal-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--bg-input);
  border-radius: 14rpx;
  font-size: 30rpx;
}

.color-list {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}

.color-dot {
  aspect-ratio: 1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 3rpx solid transparent;
}

.color-dot.active {
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 4rpx rgba(46, 170, 138, 0.3);
}

.check {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.modal-actions { display: flex; gap: 20rpx; margin-top: 40rpx; }
.modal-btn-cancel {
  flex: 1; text-align: center; padding: 24rpx;
  color: var(--text-secondary); background: var(--bg-input); border-radius: 100rpx;
}
.modal-btn-save {
  flex: 1; text-align: center; padding: 24rpx;
  color: #fff; background: var(--primary); border-radius: 100rpx; font-weight: 600;
}
