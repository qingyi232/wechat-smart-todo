.page {
  padding-bottom: 140rpx;
  min-height: 100vh;
}

.header {
  position: relative;
  padding: 120rpx 40rpx 120rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #2EAA8A 0%, #3FBF9D 60%, #248D72 120%);
}

.profile-card {
  position: relative;
  z-index: 1;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.4);
  background: #fff;
}

.user-info { flex: 1; color: #fff; }
.name { font-size: 40rpx; font-weight: 700; }
.id { font-size: 22rpx; margin-top: 6rpx; opacity: 0.85; }
.phone { font-size: 24rpx; margin-top: 4rpx; opacity: 0.9; }

.stat-row {
  margin-top: 36rpx;
  display: flex;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 0;
  align-items: center;
}

.stat-col { flex: 1; text-align: center; color: #fff; }
.stat-num { font-size: 40rpx; font-weight: 700; }
.stat-txt { font-size: 22rpx; opacity: 0.85; margin-top: 4rpx; }

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

.menu-card {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-card:first-of-type {
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.menu-item {
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.menu-title {
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  color: var(--text-hint);
  font-size: 36rpx;
}

.divider-inline {
  height: 1rpx;
  background: var(--border);
  margin-left: 124rpx;
}

.logout-btn {
  margin: 48rpx 32rpx;
  padding: 26rpx;
  text-align: center;
  background: var(--danger-light);
  color: var(--danger);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 100rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  width: 600rpx;
  padding: 48rpx 40rpx 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-field { margin-bottom: 24rpx; }
.modal-label { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 10rpx; }
.modal-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--bg-input);
  border-radius: 14rpx;
  font-size: 30rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-input);
  border-radius: 100rpx;
}

.modal-btn-save {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  color: #fff;
  background: var(--primary);
  border-radius: 100rpx;
  font-weight: 600;
}
